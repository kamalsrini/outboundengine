# ─────────────────────────────────────────────────────────────
# OutboundEngine — environment template
# Copy to `.env.local` and fill in. NEVER commit a filled-in file.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development

# Supabase Postgres (Project Settings → Database → Connection string → URI)
# Use the pooled (transaction) connection string for serverless on Vercel.
DATABASE_URL=

# Supabase project (Project Settings → API)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Keys for later phases (leave empty for Phase 1) ──

# LLM (personalization engine — Phase 4)
ANTHROPIC_API_KEY=

# Sending layer (Phase 5) — Instantly or Lemlist
INSTANTLY_API_KEY=
LEMLIST_API_KEY=

# Prospect sourcing / enrichment (Phase 8)
APOLLO_API_KEY=
